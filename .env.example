# Bituach Leumi (ביטוח לאומי) personal-portal credentials.
#
# Login fields (https://ps.btl.gov.il password-login form):
#   BTL_ID        = מספר זהות / ID number   (9 digits)        -> API field "userZehut"
#   BTL_USER_CODE = קוד משתמש / user code    (up to 8 chars)   -> API field "userName"
#   BTL_PASSWORD  = סיסמה / password          (up to 10 chars)  -> API field "password"
#
# Copy this file to ".env" and fill in your real values. The .env file is gitignored.

BTL_ID=
BTL_USER_CODE=
BTL_PASSWORD=

# Optional:
BTL_BRANCHES=           # comma-separated branches to read; blank = all. Names:
                        #   summary, mevutach, debt-insurance-health, debt-benefits,
                        #   collection, miluim, documents-sent, previous-inquiries, letters
BTL_TIMEOUT=120000      # per-request timeout in ms
BTL_DOWNLOAD_LETTERS=1  # 0 to skip downloading letter PDFs (same as omitting 'letters')
BTL_LETTERS_LIMIT=      # blank = all (caps how many NEW letters to download)
BTL_LETTERS_ALL=0       # 1 = re-download every letter (default: only new ones)
